<Window x:Class="ShadPS4Launcher.GraphicsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Graphics" Height="420" Width="440"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="Window size" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbWindowWidth" Grid.Column="0" ToolTip="Width"/>
                <TextBox x:Name="TbWindowHeight" Grid.Column="2" ToolTip="Height"/>
            </Grid>
            <TextBlock Text="Internal resolution" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbInternalWidth" Grid.Column="0"/>
                <TextBox x:Name="TbInternalHeight" Grid.Column="2"/>
            </Grid>
            <CheckBox x:Name="CbFsr" Content="FSR upscaling" Margin="0,4,0,4"/>
            <CheckBox x:Name="CbRcas" Content="RCAS sharpening" Margin="0,4,0,4"/>
            <TextBlock Text="RCAS attenuation (0-1000)" Margin="0,8,0,4" Foreground="{StaticResource TextBrush}"/>
            <Slider x:Name="SliderRcas" Minimum="0" Maximum="1000" Value="250" Margin="0,0,0,12"/>
            <TextBlock Text="CPU (Vulkan device index)" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <ComboBox x:Name="ComboCpu" Margin="0,0,0,12" MinWidth="200" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Save" Click="BtnSave_OnClick" Padding="24,8" Margin="0,0,8,0"/>
                <Button Content="Cancel" Click="BtnCancel_OnClick" Padding="24,8"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
