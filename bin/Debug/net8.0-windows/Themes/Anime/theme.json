    "game-card-ring-gradient": "linear-gradient(135deg, rgba(231,138,195,0.4) 0%, rgba(180,120,220,0.2) 50%, rgba(245,190,230,0.3) 100%)",
    "game-card-image-width": "100%",
    "game-card-image-height": "100%",
    "game-card-image-fit": "cover",
    "game-card-image-position": "center",

    "theme-tile-bg": "rgba(20, 15, 50, 0.65)",
