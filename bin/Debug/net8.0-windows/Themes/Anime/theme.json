    "settings-input-focus-border": "rgba(231, 138, 195, 0.55)",
    "settings-input-radius": "14px",
    "settings-row-hover-bg": "rgba(231, 138, 195, 0.12)",

    "panel-bg": "rgba(15, 12, 40, 0.65)",
    "panel-border": "rgba(170, 130, 200, 0.2)",
    "panel-radius": "18px",

    "game-card-size": "148px",
    "game-card-active-size": "192px",
    "game-card-radius": "18px",
