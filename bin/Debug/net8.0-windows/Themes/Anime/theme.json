    "file-list-hover-bg": "rgba(231, 138, 195, 0.15)",
    "file-list-hover-border": "rgba(245, 190, 230, 0.3)",
    "log-bg": "rgba(8, 6, 25, 0.85)",

    "quick-panel-width": "380px",
    "quick-panel-bg": "rgba(12, 10, 30, 0.96)",
    "quick-panel-border": "rgba(231, 138, 195, 0.25)",
    "quick-panel-handle": "rgba(245, 190, 230, 0.25)",
    "quick-panel-shadow": "0 25px 50px rgba(0,0,0,0.6)",

    "browser-toolbar-bg": "rgba(5, 5, 25, 0.8)",
    "browser-shell-bg": "rgba(5, 5, 20, 0.85)",
    "browser-frame-bg": "rgba(3, 3, 15, 0.92)",

    "store-shell-bg": "rgba(5, 5, 20, 0.9)",
    "store-card-bg": "rgba(15, 12, 40, 0.7)",
    "store-card-border": "rgba(160, 120, 210, 0.2)",
    "store-card-hover-border": "rgba(231, 138, 195, 0.4)",
    "store-card-radius": "18px",
    "store-badge-bg": "rgba(231, 138, 195, 0.25)",
    "store-badge-color": "#fce4f7",

    "loading-overlay-bg": "rgba(5, 5, 15, 0.9)",
    "loading-title-size": "26px",
    "loading-log-color": "rgba(245, 190, 230, 0.8)",

    "home-header-offset-x": "0px",
    "home-header-offset-y": "20px",
    "header-left-offset-x": "40px",
    "header-left-offset-y": "20px",
    "header-right-offset-x": "-40px",
    "header-right-offset-y": "20px",
    "carousel-margin-top": "30px",
    "carousel-margin-bottom": "35px",
    "carousel-offset-x": "0px",
    "carousel-offset-y": "12px",
    "games-row-gap": "28px",
    "games-row-padding-left": "45px",
    "games-row-padding-right": "45px",
    "game-info-offset-x": "45px",
    "game-info-offset-y": "-25px",
    "game-info-width": "45%",
    "actions-offset-x": "-45px",
    "actions-offset-y": "-25px",
    "settings-nav-offset-x": "45px",
    "settings-nav-offset-y": "40px",
    "settings-content-offset-x": "45px",
    "settings-content-offset-y": "40px",
    "settings-nav-width": "260px",
    "settings-content-width": "calc(100% - 320px)",

    "poster-width": "100%",
    "poster-height": "100%",
    "poster-object-fit": "cover",
    "poster-border-radius": "18px",

    "icon-size": "48px",
    "icon-object-fit": "contain",

    "game-grid-cols": "repeat(auto-fill, minmax(148px, 1fr))",
    "game-grid-gap": "22px",
    "game-grid-padding": "22px 45px"
