{
  "id": "anime_dreams_theme",
  "name": "Anime Dreams Theme",
  "description": "Pastel anime‑inspired theme with soft gradients, starry sky and gentle effects. Fixes button alignment and enhances UI with smooth transitions.",
  "author": "Константин (with ChatGPT)",
  "version": "1.0.0",
  "css_custom": true,
  "transitionMs": 400,
  "musicVolume": 0.2,
  "custom_background": {
    "enabled": true,
    "path": "image/background.jpg"
  },
  "palette": {
    "bg-color": "#0c092e",
    "text-main": "#f8f6ff",
    "text-dim": "rgba(210, 210, 230, 0.75)",
    "highlight": "#e78ac3",
    "glass-bg": "rgba(25, 20, 50, 0.25)",
    "glass-border": "rgba(240, 200, 255, 0.25)",
    "menu-shade-strong": "rgba(5, 5, 15, 0.85)",
    "menu-shade-mid": "rgba(15, 12, 35, 0.7)",
    "menu-shade-soft": "rgba(30, 20, 60, 0.4)",
    "menu-shade-line-strong": "rgba(180, 160, 210, 0.3)",
    "menu-shade-line-soft": "rgba(150, 130, 180, 0.15)"
  },
  "styles": {
    "font-family-main": "\"Segoe UI\", \"Noto Sans\", \"Helvetica Neue\", sans-serif",
    "theme-transition-ms": "350ms",
    "vignette-opacity": "0.8",
    "glass-blur": "blur(20px)",

    "header-pill-radius": "32px",
    "header-tab-bg": "rgba(231, 138, 195, 0.15)",
    "header-tab-border": "rgba(245, 190, 230, 0.25)",
    "header-block-bg": "rgba(20, 15, 40, 0.5)",
    "header-block-hover-bg": "rgba(231, 138, 195, 0.2)",
    "header-block-hover-border": "rgba(245, 190, 230, 0.3)",
    "clock-bg": "rgba(15, 10, 35, 0.55)",
    "controller-header-pill-bg": "rgba(15, 10, 35, 0.55)",

    "btn-radius": "20px",
    "btn-hover-bg": "#e78ac3",
    "btn-hover-color": "#0c092e",
    "btn-hover-shadow": "0 0 30px rgba(231, 138, 195, 0.4)",
    "btn-circle-size": "48px",

    "settings-screen-bg": "rgba(8, 6, 24, 0.98)",
    "settings-nav-btn-bg": "rgba(180, 140, 210, 0.15)",
    "settings-nav-btn-hover-bg": "rgba(231, 138, 195, 0.22)",
    "settings-nav-btn-active-bg": "rgba(231, 138, 195, 0.35)",
