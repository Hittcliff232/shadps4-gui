  "sounds": {
    "click": "sounds/click.wav",
    "select": "sounds/select.wav",
    "open": "sounds/open.wav",
    "close": "sounds/close.wav",
    "start": "sounds/start.wav",
    "music": "sounds/music.wav"
  }
