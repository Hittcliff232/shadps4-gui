<Window x:Class="ShadPS4Launcher.BrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Browser"
        Width="1320"
        Height="840"
        MinWidth="900"
        MinHeight="560"
        Background="#0B111B"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#15243A" BorderBrush="#2A3E5F" BorderThickness="0,0,0,1" Padding="8">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button x:Name="BtnBack" Content="Back" Height="30" Margin="0,0,6,0" Padding="10,0" Click="BtnBack_OnClick"/>
                    <Button x:Name="BtnForward" Content="Next" Height="30" Margin="0,0,6,0" Padding="10,0" Click="BtnForward_OnClick"/>
                    <Button x:Name="BtnReload" Content="Reload" Height="30" Margin="0,0,6,0" Padding="10,0" Click="BtnReload_OnClick"/>
                    <Button x:Name="BtnHome" Content="Home" Height="30" Margin="0,0,8,0" Padding="10,0" Click="BtnHome_OnClick"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="8,0,0,0">
                    <Button x:Name="BtnKeyboard" Content="Keyboard" Height="30" Margin="0,0,8,0" Padding="10,0" Click="BtnKeyboard_OnClick"/>
                    <Button x:Name="BtnClose" Content="Close" Height="30" Padding="12,0" Click="BtnClose_OnClick"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TbUrl"
                             Grid.Column="0"
                             Height="30"
                             VerticalContentAlignment="Center"
                             Margin="0,0,8,0"
                             KeyDown="TbUrl_OnKeyDown"/>
                    <Button x:Name="BtnGo" Grid.Column="1" Content="Go" Height="30" Padding="14,0" Click="BtnGo_OnClick"/>
                </Grid>
            </DockPanel>
        </Border>

        <ProgressBar x:Name="LoadingBar" Grid.Row="1" IsIndeterminate="True" Visibility="Collapsed"/>

        <wv2:WebView2 x:Name="BrowserView" Grid.Row="2"/>
    </Grid>
</Window>
