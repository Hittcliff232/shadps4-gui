<Window x:Class="ShadPS4Launcher.PathsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paths — Game folders" Height="400" Width="560"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Game install folders (containing eboot.bin / sce_sys)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
        <ListBox x:Name="ListPaths" Grid.Row="1" Margin="0,0,0,12"
                 Foreground="{StaticResource TextBrush}" Background="{StaticResource SurfaceBrush}"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnAdd" Content="Add folder..." Click="BtnAdd_OnClick" Margin="0,0,8,0" Padding="16,8"/>
            <Button x:Name="BtnRemove" Content="Remove" Click="BtnRemove_OnClick" Margin="0,0,8,0" Padding="16,8"/>
            <Button Content="Save" Click="BtnSave_OnClick" Padding="16,8" Margin="0,0,8,0"/>
            <Button Content="Close" Click="BtnClose_OnClick" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>
