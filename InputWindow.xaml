<Window x:Class="ShadPS4Launcher.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input" Height="260" Width="400"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Input config is in user folder: input_config\default.ini" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <CheckBox x:Name="CbMotionControls" Content="Motion controls" Margin="0,4,0,4"/>
        <CheckBox x:Name="CbBackgroundController" Content="Background controller input" Margin="0,4,0,4"/>
        <Button x:Name="BtnOpenInputConfig" Content="Open input config folder" Margin="0,16,0,0" Click="BtnOpenInputConfig_OnClick" HorizontalAlignment="Left"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Save" Click="BtnSave_OnClick" Padding="24,8" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="BtnCancel_OnClick" Padding="24,8"/>
        </StackPanel>
    </StackPanel>
</Window>
