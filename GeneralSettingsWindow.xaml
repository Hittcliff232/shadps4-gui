<Window x:Class="ShadPS4Launcher.GeneralSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — General" Height="520" Width="520"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="Emulator path" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbEmulatorPath" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse..." Click="BtnBrowseEmulator_OnClick"/>
            </Grid>
            <TextBlock Text="User data folder (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbUserDir" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse..." Click="BtnBrowseUserDir_OnClick"/>
            </Grid>
            <TextBlock Text="Addon folder (DLC)" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbAddonDir" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Browse..." Click="BtnBrowseAddonDir_OnClick"/>
            </Grid>
            <CheckBox x:Name="CbFullscreen" Content="Start in fullscreen" Margin="0,4,0,4"/>
            <CheckBox x:Name="CbShowFps" Content="Show FPS" Margin="0,4,0,4"/>
            <CheckBox x:Name="CbIgnoreGamePatch" Content="Ignore game patch" Margin="0,4,0,4"/>
            <TextBlock Text="Patch file (optional)" Margin="0,12,0,4" Foreground="{StaticResource TextBrush}"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TbPatchFile" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="..." Click="BtnBrowsePatch_OnClick"/>
            </Grid>
            <TextBlock Text="Override root (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <TextBox x:Name="TbOverrideRoot" Margin="0,0,0,12"/>
            <TextBlock Text="Wait for PID (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <TextBox x:Name="TbWaitForPid" Margin="0,0,0,12"/>
            <TextBlock Text="Extra launch args after -- (optional)" Margin="0,0,0,4" Foreground="{StaticResource TextBrush}"/>
            <TextBox x:Name="TbCustomLaunchArgs" Margin="0,0,0,12"/>
            <CheckBox x:Name="CbWaitForDebugger" Content="Wait for debugger" Margin="0,4,0,4"/>
            <CheckBox x:Name="CbConfigClean" Content="Config: clean mode" Margin="0,4,0,4"/>
            <CheckBox x:Name="CbConfigGlobal" Content="Config: global mode" Margin="0,4,0,4"/>
            <CheckBox x:Name="CbLogAppend" Content="Append to log" Margin="0,4,0,4"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Save" Click="BtnSave_OnClick" Padding="24,8" Margin="0,0,8,0"/>
                <Button Content="Cancel" Click="BtnCancel_OnClick" Padding="24,8"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
