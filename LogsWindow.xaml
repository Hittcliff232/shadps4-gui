<Window x:Class="ShadPS4Launcher.LogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShadPS4 Logs" Height="500" Width="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Log output (from ShadPS4 user folder)" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
        <TextBox x:Name="TbLog" Grid.Row="1" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12"
                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                 Padding="8" Margin="0,0,0,12"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Load log" Click="BtnLoad_OnClick" Margin="0,0,8,0" Padding="16,8"/>
            <Button Content="Open log folder" Click="BtnOpenFolder_OnClick" Margin="0,0,8,0" Padding="16,8"/>
            <Button Content="Close" Click="BtnClose_OnClick" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>
